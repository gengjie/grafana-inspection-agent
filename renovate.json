{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "Asia/Shanghai",
  "dependencyDashboard": true,
  "labels": [
    "dependencies",
    "renovate"
  ],
  "enabledManagers": [
    "pep621",
    "uv",
    "dockerfile",
    "gitlabci"
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "before 6am on monday"
    ]
  },
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "packageRules": [
    {
      "matchManagers": [
        "pep621",
        "uv"
      ],
      "groupName": "python-non-major-dependencies",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "digest",
        "pin"
      ]
    },
    {
      "matchManagers": [
        "dockerfile"
      ],
      "groupName": "docker-base-images",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "digest",
        "pin"
      ]
    },
    {
      "matchManagers": [
        "gitlabci"
      ],
      "groupName": "gitlab-ci-includes-and-components",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "digest",
        "pin"
      ]
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "addLabels": [
        "major-update"
      ]
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "security"
    ]
  }
}
